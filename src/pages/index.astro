    order: 8,
    thumbnailUrl: '/img/freelance.webp',
    media: [
      { title: 'Janzu', url: 'https://www.instagram.com/reel/C6M3CqXxSET/', type: 'instagram' },
      { title: 'Hilando Fino', url: 'https://www.instagram.com/reel/CtH17SPLkLO/', type: 'instagram' },
      { title: 'Coral Sintético', url: 'https://www.instagram.com/reel/CNQPb8CBBjQ/', type: 'instagram' },
    ],
  },
];

const fallbackSettings: SiteSettings = {
  heroName: 'Karina Elizondo',
  heroRoleEs: 'ESTRATEGA CREATIVA Y PRODUCTORA DE VIDEO',
  heroRoleEn: 'CREATIVE STRATEGIST & VIDEO PRODUCER',
  heroTaglineEs: 'Estrategia de Contenido · Producción de Video · Narrativa de Marca',
  heroTaglineEn: 'Content Strategy · Video Production · Brand Storytelling',
  footerQuoteTitleEs: '« Gratitud al reconocimiento »',
  footerQuoteTitleEn: '« Gratitude for the recognition »',
  footerQuoteEs: 'Mi intención es mostrar una pincelada de proyectos en los que he dirigido, colaborado o participado con mucho amor y dedicación.',
  footerQuoteEn: 'My intention is to show a glimpse of projects I have directed, collaborated on, or participated in with much love and dedication.',
  socialLinks: [],
};

const hasSanityConfig = Boolean(import.meta.env.SANITY_PROJECT_ID);

let projects: Project[] = fallbackProjects;
let settings: SiteSettings = fallbackSettings;

if (hasSanityConfig) {
  try {
    const [fetchedProjects, fetchedSettings] = await Promise.all([
      client.fetch(allProjectsQuery),
      client.fetch(siteSettingsQuery),
    ]);
    if (fetchedProjects?.length) projects = fetchedProjects;
    if (fetchedSettings) settings = fetchedSettings;
  } catch {
  }
}
---

<BaseLayout title="Karina Elizondo — Productora Audiovisual">
  <Hero
    heroName={settings.heroName}
    heroRoleEs={settings.heroRoleEs}
    heroRoleEn={settings.heroRoleEn}
    heroTaglineEs={settings.heroTaglineEs}
    heroTaglineEn={settings.heroTaglineEn}
  />

  <!-- Fotografía preview section -->
  <section class="w-full py-10 md:py-[60px] px-6 md:px-[120px] border-b border-border-warm">
    <div class="mb-8">
      <h2 class="font-display text-[28px] md:text-[36px] text-text-primary" data-es>Fotografía</h2>
      <h2 class="font-display text-[28px] md:text-[36px] text-text-primary hidden" data-en>Photography</h2>
    </div>
    <div class="flex flex-col md:flex-row gap-4 md:gap-[20px] overflow-x-scroll">
      <img src="/photos/1.webp" alt="" class="w-full md:w-auto md:flex-1 h-[40vh] md:h-[300px] object-cover flex-shrink-0" loading="lazy" />
      <img src="/photos/6.webp" alt="" class="w-full md:w-auto md:flex-1 h-[40vh] md:h-[300px] object-cover flex-shrink-0" loading="lazy" />
      <img src="/photos/3.webp" alt="" class="w-full md:w-auto md:flex-1 h-[40vh] md:h-[300px] object-cover flex-shrink-0" loading="lazy" />
      <img src="/photos/4.webp" alt="" class="w-full md:w-auto md:flex-1 h-[40vh] md:h-[300px] object-cover flex-shrink-0" loading="lazy" />
      <img src="/photos/5.webp" alt="" class="w-full md:w-auto md:flex-1 h-[40vh] md:h-[300px] object-cover flex-shrink-0" loading="lazy" />
      <img src="/photos/2.webp" alt="" class="w-full md:w-auto md:flex-1 h-[40vh] md:h-[300px] object-cover flex-shrink-0" loading="lazy" />
    </div>
    <div class="mt-8">
      <a href="/fotografia" class="inline-flex items-center gap-2 font-mono text-[13px] tracking-[1.5px] text-accent-sienna hover:text-accent-ochre transition-colors">
        <span data-es>VER TODOS</span>
        <span data-en class="hidden">VIEW ALL</span>
        <span>→</span>
      </a>
    </div>
  </section>

  <!-- Audiovisual projects section -->
   <section class="w-full py-10 md:py-[60px] px-6 md:px-[120px] border-b border-border-warm">
    <div class="mb-8">
      <h2 class="font-display text-[28px] md:text-[36px] text-text-primary" data-es>Audiovisual</h2>
      <h2 class="font-display text-[28px] md:text-[36px] text-text-primary hidden" data-en>Audiovisual</h2>
    </div>
  {projects.map((project, i) => {
    const firstMedia = project.media?.[0];
    const thumbnail = getThumbnailUrl(project);
    return (
      <ProjectSection
        index={i}
        title={project.title}
        titleEn={project.titleEn}
        description={project.description}
        descriptionEn={project.descriptionEn}
        order={project.order}
        videoUrl={firstMedia?.url}
        mediaType={firstMedia?.type}
        thumbnail={thumbnail}
        links={project.media?.map((m) => ({
          title: m.title,
          url: m.url,
          type: m.type,
        })) ?? []}
      />
    );
  })}
  </section>
  <Footer
    footerQuoteTitleEs={settings.footerQuoteTitleEs}
    footerQuoteTitleEn={settings.footerQuoteTitleEn}
    footerQuoteEs={settings.footerQuoteEs}
    footerQuoteEn={settings.footerQuoteEn}
    socialLinks={settings.socialLinks}
  />

  <VideoModal />
  <ContactModal />
</BaseLayout>
