---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectSection from '../components/ProjectSection.astro';
import VideoModal from '../components/VideoModal.astro';
import ContactModal from '../components/ContactModal.astro';
import Footer from '../components/Footer.astro';
import { client } from '../../sanity/lib/client';
import { allProjectsQuery, siteSettingsQuery, getThumbnailUrl } from '../lib/queries';

interface Project {
  title: string;
  slug: string;
  titleEn: string;
  description: string;
  descriptionEn: string;
  order: number;
  thumbnailUrl: string;
  media: Array<{ title: string; url: string; type: string }>;
}

interface SiteSettings {
  heroName: string;
  heroRoleEs: string;
  heroRoleEn: string;
  heroTaglineEs: string;
  heroTaglineEn: string;
  footerQuoteTitleEs: string;
  footerQuoteTitleEn: string;
  footerQuoteEs: string;
  footerQuoteEn: string;
  socialLinks: Array<{ platform: string; url: string }>;
}

const fallbackProjects: Project[] = [
  {
    title: 'Mujeres Fuertes',
    slug: 'mujeres-fuertes',
    titleEn: 'Mujeres Fuertes',
    description: 'Serie documental que retrata la fuerza y resiliencia de mujeres centroamericanas.',
    descriptionEn: 'Documentary series portraying the strength and resilience of Central American women.',
    order: 1,
    thumbnailUrl: '/img/docu.webp',
    media: [
      { title: 'Teaser', url: 'https://www.youtube.com/watch?v=S7LNQHob1AY', type: 'youtube' },
      { title: 'Documental', url: 'https://www.youtube.com/watch?v=S7LNQHob1AY', type: 'youtube' },
    ],
  },
  {
    title: 'Recuperación Histórica CCT',
    slug: 'recuperacion-historica-cct',
    titleEn: 'Historical Recovery CCT',
    description: 'Postproducción de Semblanzas para el Centro Científico Tropical.',
    descriptionEn: 'Post-production of Semblanzas for the Tropical Scientific Center.',
    order: 2,
    thumbnailUrl: '/img/kattiana.webp',
    media: [
      { title: 'Katiana', url: 'https://www.youtube.com/watch?v=HyN3LsIS4Tk', type: 'youtube' },
      { title: 'Ana Báez', url: 'https://www.youtube.com/watch?v=6FjA_as6UXU', type: 'youtube' },
      { title: 'Vivienne Solís', url: 'https://www.youtube.com/watch?v=3797QaUp3vU', type: 'youtube' },
      { title: 'Katiana Reel', url: 'https://www.instagram.com/reel/DHBo510vS8y/', type: 'instagram' },
    ],
  },
  {
    title: 'Mujer Salvaje',
    slug: 'mujer-salvaje',
    titleEn: 'Wild Woman',
    description: 'Exploración visual de la mujer y su conexión con la naturaleza salvaje.',
    descriptionEn: 'Visual exploration of woman and her connection to wild nature.',
    order: 3,
    thumbnailUrl: '/img/msalvaje.webp',
    media: [
      { title: 'Tráiler', url: 'https://drive.google.com/file/d/1ZfDQrP0cDI3bJjveYfg6Val3QhMfJbE4/preview', type: 'drive' },
      { title: 'Reel', url: 'https://www.instagram.com/reel/DF0aNbLReEi/', type: 'instagram' },
    ],
  },
  {
    title: 'Producers Trust',
    slug: 'producers-trust',
    titleEn: 'Producers Trust',
    description: 'Producción audiovisual para Producers Trust y sus marcas asociadas.',
    descriptionEn: 'Audiovisual production for Producers Trust and associated brands.',
    order: 4,
    thumbnailUrl: '',
    media: [
      { title: 'Quinoa', url: 'https://www.youtube.com/watch?v=uaI_5sYb754', type: 'youtube' },
      { title: 'StoryBird', url: 'https://www.youtube.com/watch?v=pXpoXD8k1F0', type: 'youtube' },
      { title: 'Alaffia', url: 'https://www.youtube.com/watch?v=03jLgAV0FlI', type: 'youtube' },
      { title: 'Instagram', url: 'https://www.instagram.com/producersmarket/', type: 'instagram' },
    ],
  },
  {
    title: 'Regenerative Homestead',
    slug: 'regenerative-homestead',
    titleEn: 'Regenerative Homestead',
    description: 'Documental sobre prácticas regenerativas y vida sostenible.',
    descriptionEn: 'Documentary about regenerative practices and sustainable living.',
    order: 5,
    thumbnailUrl: '',
    media: [
      { title: 'Documental', url: 'https://www.youtube.com/watch?v=OwBdLVUE9Jw', type: 'youtube' },
    ],
  },
  {
    title: 'ESD Professionals',
    slug: 'esd-professionals',
    titleEn: 'ESD Professionals',
    description: 'Contenido audiovisual profesional para ESD.',
    descriptionEn: 'Professional audiovisual content for ESD.',
    order: 6,
    thumbnailUrl: '/img/ESD.webp',
    media: [
      { title: 'Video', url: 'https://drive.google.com/file/d/1c7O1Vxg8Cjc7NoKbyznwow-vk8fjfI4G/preview', type: 'drive' },
    ],
  },
  {
    title: 'Curso Mujeres Fuertes',
    slug: 'curso-mujeres-fuertes',
    titleEn: 'Strong Women Course',
    description: 'Curso online de empoderamiento para mujeres.',
    descriptionEn: 'Online empowerment course for women.',
    order: 7,
    thumbnailUrl: '/img/curso.webp',
    media: [
      { title: 'Curso Online', url: 'https://hotmart.com/es/marketplace/productos/mujeresfuertes/M53477666S', type: 'external' },
    ],
  },
  {
    title: 'Freelance Reels',
    slug: 'freelance-reels',
    titleEn: 'Freelance Reels',
    description: 'Reels y contenido corto para diversos clientes.',
